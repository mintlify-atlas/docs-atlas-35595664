  "projectType": "api-service",
  "projectName": "LMS Backend",
  "projectDescription": "A secure, modular Node.js/Express REST API backend for a Learning Management System with user auth, course management, lecture uploads, progress tracking, and Stripe/Razorpay payment integration.",
  "theme": "luma",
  "primaryColor": "#4F46E5",
